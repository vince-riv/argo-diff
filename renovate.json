{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "packageRules": [{
        "matchPackageNames": ["ghcr.io/vince-riv/argo-diff"],
        "pinDigests": false
    }, {
        "matchPackageNames": [
            "google/go-github",
            "/^github\\.com/google/go-github/"
        ],
        "groupName": "go-github"
    }],
    "postUpdateOptions": [
        "gomodUpdateImportPaths"
    ]
}
